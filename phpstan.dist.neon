parameters:
    level: 6
    ignoreErrors:
        - '#no value type specified in iterable type array#'
        - '#generic interface Doctrine\\Common\\Collections\\Collection#'
        - '#is not generic#'
        - '#Property App\\Entity\\.+::\$id \(int\|null\) is never assigned int#'
        - '#Call to function method_exists\(\).+will always evaluate to true#'
    paths:
        - bin/
        - config/
        - public/
        - src/
        - tests/
