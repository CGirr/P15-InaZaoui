{% extends 'admin.html.twig' %}

{% block admin %}
    <div class="d-flex justify-content-between align-items-center">
        <h1>Liste des invités</h1>
        <a href="{{ path('admin_guest_add') }}" class="btn btn-primary">Ajouter un invité</a>
    </div>
    <table class="table">
        <thead>
        <tr>
            <th>Nom</th>
            <th>Email</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for guest in guests %}
            <tr>
                <td>{{ guest.name }}</td>
                <td>{{ guest.email }}</td>
                <td>{{ guest.description }}</td>
                <td>
                    <div class="d-flex gap-2">
                        {% if guest.blocked == false %}
                            <a href="{{ path('admin_guest_block', {id: guest.id}) }}" class="btn btn-danger">Bloquer</a>
                        {%  else %}
                            <a href="{{ path('admin_guest_block', {id: guest.id}) }}" class="btn btn-success">Débloquer</a>
                        {% endif %}
                        <a href="" class="btn btn-danger">Supprimer</a>
                    </div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
